# PramanaSystems — environment variable reference
# Copy to .env and fill in values before running docker compose up.
# .env is gitignored; never commit real key material.

# ── API authentication ────────────────────────────────────────────────────────
# Bearer token required for all API requests when set.
# If unset, the server runs in unauthenticated dev mode.
# Generate a random key: openssl rand -hex 32
PRAMANA_API_KEY=

# ── Ed25519 signing keys ──────────────────────────────────────────────────────
# PEM-encoded Ed25519 private key (PKCS8) used to sign execution attestations.
# If unset, the server falls back to dev-keys on disk, then generates an
# ephemeral in-memory key pair (lost on restart — not suitable for production).
#
# Generate a production key pair:
#   openssl genpkey -algorithm ed25519 -out private.pem
#   openssl pkey -pubout -in private.pem -out public.pem
#
# Then export for use here:
#   PRAMANA_PRIVATE_KEY="$(cat private.pem)"
#   PRAMANA_PUBLIC_KEY="$(cat public.pem)"
PRAMANA_PRIVATE_KEY=

# PEM-encoded Ed25519 public key (SPKI) used for attestation verification.
# Must correspond to PRAMANA_PRIVATE_KEY.
PRAMANA_PUBLIC_KEY=

# ── Server network ────────────────────────────────────────────────────────────
# TCP port the governance server listens on. Default: 3000.
PORT=3000

# Network interface to bind. Default: 0.0.0.0 (all interfaces).
# Set to 127.0.0.1 to restrict to localhost only.
HOST=0.0.0.0
