{
  "schema_version": "1.0.0",

  "signals": {
    "symptom_severity": {
      "type": "number",
      "required": true
    },

    "heart_rate_elevated": {
      "type": "boolean",
      "required": true
    }
  },

  "decision": "escalate",

  "rules": {
    "any": [
      {
        "signal": "symptom_severity",
        "greater_than": 8
      },

      {
        "signal": "heart_rate_elevated",
        "equals": true
      }
    ]
  }
}


